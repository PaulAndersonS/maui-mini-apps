<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WeatherForecast.ViewModels"
             xmlns:models="clr-namespace:WeatherForecast.Models"
             xmlns:chart="clr-namespace:Syncfusion.Maui.Charts;assembly=Syncfusion.Maui.Charts"
             xmlns:listview="clr-namespace:Syncfusion.Maui.ListView;assembly=Syncfusion.Maui.ListView"
             xmlns:tabview="clr-namespace:Syncfusion.Maui.TabView;assembly=Syncfusion.Maui.TabView"
             xmlns:input="clr-namespace:Syncfusion.Maui.Inputs;assembly=Syncfusion.Maui.Inputs"
             xmlns:gauge="clr-namespace:Syncfusion.Maui.Gauges;assembly=Syncfusion.Maui.Gauges"
             xmlns:progressbar="clr-namespace:Syncfusion.Maui.ProgressBar;assembly=Syncfusion.Maui.ProgressBar"
             xmlns:ptr="clr-namespace:Syncfusion.Maui.PullToRefresh;assembly=Syncfusion.Maui.PullToRefresh"
             xmlns:core="clr-namespace:Syncfusion.Maui.Shimmer;assembly=Syncfusion.Maui.Core"
             xmlns:badge="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
             x:Class="WeatherForecast.Views.WeatherDashboardPage"
             x:DataType="vm:WeatherViewModel"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False">

    <!-- ═══════════════════════════════════  Safe Area  ═══════════════════════════════════ -->
    <ContentPage.Padding>
        <OnPlatform x:TypeArguments="Thickness">
            <On Platform="iOS"     Value="0,47,0,0" />
            <On Platform="Android" Value="0,0,0,0" />
        </OnPlatform>
    </ContentPage.Padding>

    <!-- ════════════════════════════════  Page Background  ═══════════════════════════════ -->
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#0B1C2D" Offset="0.0" />
            <GradientStop Color="#0D2236" Offset="0.5" />
            <GradientStop Color="#102A43" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <!-- ═══════════════════════════════════  Resources  ═══════════════════════════════════ -->
    <ContentPage.Resources>
        <ResourceDictionary>

            <!-- ── Colour tokens ────────────────────────────────────────────── -->
            <Color x:Key="TextPrimary">#FFFFFF</Color>
            <Color x:Key="TextSecondary">#8FA8C0</Color>
            <Color x:Key="TextTertiary">#4A6580</Color>
            <Color x:Key="Cyan">#38BDF8</Color>
            <Color x:Key="CyanDim">#1A5F80</Color>
            <Color x:Key="TempWhite">#F0F8FF</Color>
            <Color x:Key="HighRed">#F87171</Color>
            <Color x:Key="LowBlue">#60A5FA</Color>
            <Color x:Key="HumidTeal">#2DD4BF</Color>
            <Color x:Key="WindPurple">#A78BFA</Color>
            <!-- Glass — explicit hex so Android doesn't misinterpret -->
            <Color x:Key="GlassBg">#12FFFFFF</Color>
            <Color x:Key="GlassBgStrong">#1AFFFFFF</Color>
            <Color x:Key="GlassBorder">#20FFFFFF</Color>
            <Color x:Key="GlassBorderStrong">#30FFFFFF</Color>
            <Color x:Key="Overlay">#CC0B1C2D</Color>

            <!-- ── Glass card ────────────────────────────────────────────────── -->
            <Style x:Key="Card" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource GlassBg}" />
                <Setter Property="Stroke"          Value="{StaticResource GlassBorder}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape"     Value="RoundRectangle 20" />
                <Setter Property="Padding"         Value="16" />
                <Setter Property="Margin"          Value="20,0,20,16" />
            </Style>

            <!-- ── Stat card (3-up grid) ─────────────────────────────────────── -->
            <Style x:Key="StatCard" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource GlassBg}" />
                <Setter Property="Stroke"          Value="{StaticResource GlassBorder}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape"     Value="RoundRectangle 20" />
                <Setter Property="Padding"         Value="0,14" />
            </Style>

            <!-- ── Section heading ──────────────────────────────────────────── -->
            <Style x:Key="SectionHead" TargetType="Label">
                <Setter Property="TextColor"        Value="{StaticResource TextSecondary}" />
                <Setter Property="FontSize"         Value="11" />
                <Setter Property="FontAttributes"   Value="Bold" />
                <Setter Property="CharacterSpacing" Value="1.8" />
                <Setter Property="TextTransform"    Value="Uppercase" />
                <Setter Property="Margin"           Value="20,24,20,10" />
            </Style>

            <!-- ── Hourly mini card ──────────────────────────────────────────── -->
            <Style x:Key="HourlyCard" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource GlassBg}" />
                <Setter Property="Stroke"          Value="{StaticResource GlassBorder}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape"     Value="RoundRectangle 16" />
                <Setter Property="Padding"         Value="8,12" />
                <Setter Property="Margin"          Value="0,2,10,2" />
            </Style>

            <!-- ── Daily forecast row ───────────────────────────────────────── -->
            <Style x:Key="DayCard" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource GlassBg}" />
                <Setter Property="Stroke"          Value="{StaticResource GlassBorder}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape"     Value="RoundRectangle 20" />
                <Setter Property="Padding"         Value="16,14" />
            </Style>

        </ResourceDictionary>
    </ContentPage.Resources>

    <!-- ═══════════════════════════════════  Root  ════════════════════════════════════════ -->
    <Grid>

        <!-- ─────────────────────────────────  TAB VIEW  ───────────────────────────────── -->
        <tabview:SfTabView TabWidthMode="SizeToContent"
                           TabBarBackground="Transparent"
                           IndicatorBackground="{StaticResource Cyan}"
                           IndicatorPlacement="Bottom"
                           TabBarHeight="48">

            <!-- ══════════════════════════════  TODAY TAB  ══════════════════════════════ -->
            <tabview:SfTabItem Header="  Today  "
                               TextColor="{StaticResource Cyan}"
                               FontSize="13"
                               FontAttributes="Bold">
                <tabview:SfTabItem.Content>
                    <ptr:SfPullToRefresh RefreshCommand="{Binding PullToRefreshCommand}"
                                         IsRefreshing="{Binding IsRefreshing}"
                                         PullingThreshold="80">
                        <ptr:SfPullToRefresh.PullableContent>

                            <ScrollView>
                                <VerticalStackLayout Spacing="0">

                                    <!-- ═══════════════════  HERO  ═══════════════════════ -->
                                    <Grid Padding="20,24,20,0">

                                        <!-- Ambient glow orb behind emoji -->
                                        <Ellipse HorizontalOptions="End"
                                                 VerticalOptions="Start"
                                                 WidthRequest="180" HeightRequest="180"
                                                 Margin="0,10,0,0"
                                                 Opacity="0.12">
                                            <Ellipse.Fill>
                                                <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                                                    <GradientStop Color="#38BDF8" Offset="0" />
                                                    <GradientStop Color="Transparent" Offset="1" />
                                                </RadialGradientBrush>
                                            </Ellipse.Fill>
                                        </Ellipse>

                                        <VerticalStackLayout Spacing="0">

                                            <!-- City + Updated -->
                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                                                <Label Grid.Column="0"
                                                       Text="📍" FontSize="13"
                                                       VerticalOptions="Center" Opacity="0.6" />
                                                <Label Grid.Column="1"
                                                       Text="{Binding CityName}"
                                                       TextColor="{StaticResource TextPrimary}"
                                                       FontSize="15" FontAttributes="Bold"
                                                       VerticalOptions="Center" />
                                                <Label Grid.Column="2"
                                                       Text="{Binding LastUpdated}"
                                                       TextColor="{StaticResource TextTertiary}"
                                                       FontSize="10"
                                                       HorizontalTextAlignment="End"
                                                       VerticalOptions="Center" />
                                            </Grid>

                                            <!-- Large temp + emoji -->
                                            <Grid ColumnDefinitions="*,Auto"
                                                  Margin="0,8,0,0">
                                                <VerticalStackLayout Grid.Column="0" Spacing="0">

                                                    <!-- Temperature -->
                                                    <Label Text="{Binding CurrentTempDisplay}"
                                                           TextColor="{StaticResource TempWhite}"
                                                           FontSize="80"
                                                           FontAttributes="Bold"
                                                           LineHeight="0.9"
                                                           CharacterSpacing="-1" />

                                                    <!-- Condition badge -->
                                                    <Border BackgroundColor="{StaticResource GlassBgStrong}"
                                                            Stroke="{StaticResource GlassBorderStrong}"
                                                            StrokeThickness="1"
                                                            StrokeShape="RoundRectangle 24"
                                                            Padding="14,6"
                                                            HorizontalOptions="Start"
                                                            Margin="0,10,0,0">
                                                        <Label Text="{Binding Description}"
                                                               TextColor="{StaticResource TextPrimary}"
                                                               FontSize="13"
                                                               FontAttributes="Bold" />
                                                    </Border>

                                                    <!-- Feels like -->
                                                    <Label Text="{Binding FeelsLikeDisplay}"
                                                           TextColor="{StaticResource TextSecondary}"
                                                           FontSize="13"
                                                           Margin="0,10,0,0" />

                                                    <!-- H / L -->
                                                    <HorizontalStackLayout Spacing="10" Margin="0,6,0,0">
                                                        <Label Text="{Binding HighTempDisplay}"
                                                               TextColor="{StaticResource HighRed}"
                                                               FontSize="14" FontAttributes="Bold" />
                                                        <Label Text="·"
                                                               TextColor="{StaticResource TextTertiary}"
                                                               FontSize="14" />
                                                        <Label Text="{Binding LowTempDisplay}"
                                                               TextColor="{StaticResource LowBlue}"
                                                               FontSize="14" FontAttributes="Bold" />
                                                    </HorizontalStackLayout>

                                                </VerticalStackLayout>

                                                <!-- Weather emoji -->
                                                <Label Grid.Column="1"
                                                       Text="{Binding CurrentWeatherEmoji}"
                                                       FontSize="88"
                                                       VerticalOptions="Center"
                                                       HorizontalOptions="End" />
                                            </Grid>

                                            <!-- ═══════════  3 STAT CARDS  ═══════════ -->
                                            <Grid ColumnDefinitions="*,*,*"
                                                  ColumnSpacing="10"
                                                  Margin="0,20,0,0">

                                                <!-- Humidity -->
                                                <Border Grid.Column="0" Style="{StaticResource StatCard}">
                                                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                                        <!-- Icon circle -->
                                                        <Border BackgroundColor="#1A2DD4BF"
                                                                StrokeThickness="0"
                                                                StrokeShape="RoundRectangle 22"
                                                                WidthRequest="44" HeightRequest="44"
                                                                HorizontalOptions="Center">
                                                            <Label Text="💧" FontSize="20"
                                                                   HorizontalOptions="Center"
                                                                   VerticalOptions="Center" />
                                                        </Border>
                                                        <Label Text="{Binding HumidityDisplay}"
                                                               TextColor="{StaticResource HumidTeal}"
                                                               FontSize="16" FontAttributes="Bold"
                                                               HorizontalTextAlignment="Center" />
                                                        <Label Text="Humidity"
                                                               TextColor="{StaticResource TextTertiary}"
                                                               FontSize="10"
                                                               HorizontalTextAlignment="Center" />
                                                    </VerticalStackLayout>
                                                </Border>

                                                <!-- Wind -->
                                                <Border Grid.Column="1" Style="{StaticResource StatCard}">
                                                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                                        <Border BackgroundColor="#1AA78BFA"
                                                                StrokeThickness="0"
                                                                StrokeShape="RoundRectangle 22"
                                                                WidthRequest="44" HeightRequest="44"
                                                                HorizontalOptions="Center">
                                                            <Label Text="💨" FontSize="20"
                                                                   HorizontalOptions="Center"
                                                                   VerticalOptions="Center" />
                                                        </Border>
                                                        <Label Text="{Binding WindSpeedDisplay}"
                                                               TextColor="{StaticResource WindPurple}"
                                                               FontSize="16" FontAttributes="Bold"
                                                               HorizontalTextAlignment="Center" />
                                                        <Label Text="Wind"
                                                               TextColor="{StaticResource TextTertiary}"
                                                               FontSize="10"
                                                               HorizontalTextAlignment="Center" />
                                                    </VerticalStackLayout>
                                                </Border>

                                                <!-- Current Temp -->
                                                <Border Grid.Column="2" Style="{StaticResource StatCard}">
                                                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                                        <Border BackgroundColor="#1A38BDF8"
                                                                StrokeThickness="0"
                                                                StrokeShape="RoundRectangle 22"
                                                                WidthRequest="44" HeightRequest="44"
                                                                HorizontalOptions="Center">
                                                            <Label Text="🌡️" FontSize="20"
                                                                   HorizontalOptions="Center"
                                                                   VerticalOptions="Center" />
                                                        </Border>
                                                        <Label Text="{Binding CurrentTempDisplay}"
                                                               TextColor="{StaticResource Cyan}"
                                                               FontSize="16" FontAttributes="Bold"
                                                               HorizontalTextAlignment="Center" />
                                                        <Label Text="Feels"
                                                               TextColor="{StaticResource TextTertiary}"
                                                               FontSize="10"
                                                               HorizontalTextAlignment="Center" />
                                                    </VerticalStackLayout>
                                                </Border>

                                            </Grid>

                                            <!-- ═══════════  SEARCH BAR  ═══════════ -->
                                            <Border BackgroundColor="{StaticResource GlassBg}"
                                                    Stroke="{StaticResource GlassBorder}"
                                                    StrokeThickness="1"
                                                    StrokeShape="RoundRectangle 24"
                                                    Padding="14,4"
                                                    Margin="0,20,0,0">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                                    <Label Grid.Column="0"
                                                           Text="🔍" FontSize="16"
                                                           VerticalOptions="Center" Opacity="0.5" />
                                                    <input:SfAutocomplete
                                                        Grid.Column="1"
                                                        ItemsSource="{Binding CitySuggestions}"
                                                        Text="{Binding SelectedCity, Mode=TwoWay}"
                                                        ReturnCommand="{Binding SearchCommand}"
                                                        Placeholder="Search city…"
                                                        PlaceholderColor="{StaticResource TextTertiary}"
                                                        TextColor="{StaticResource TextPrimary}"
                                                        MaxDropDownHeight="200" ShowBorder="False"
                                                        BackgroundColor="Transparent" />
                                                </Grid>
                                            </Border>

                                            <!-- Error banner -->
                                            <Border IsVisible="{Binding HasError}"
                                                    BackgroundColor="#22F87171"
                                                    Stroke="#40F87171"
                                                    StrokeThickness="1"
                                                    StrokeShape="RoundRectangle 12"
                                                    Padding="14,10"
                                                    Margin="0,12,0,0">
                                                <Label Text="{Binding ErrorMessage}"
                                                       TextColor="#F87171"
                                                       FontSize="12"
                                                       HorizontalTextAlignment="Center" />
                                            </Border>

                                        </VerticalStackLayout>
                                    </Grid>

                                    <!-- ═══════════════  SHIMMER  ═════════════════ -->
                                    <core:SfShimmer IsActive="True"
                                                     IsVisible="{Binding IsLoading}"
                                                     HeightRequest="500"
                                                     Margin="0,24,0,0"
                                                     Type="Article" />

                                    <!-- ═══════════════  CONTENT  ═════════════════ -->
                                    <VerticalStackLayout IsVisible="{Binding IsContentVisible}" Spacing="0">

                                        <!-- ────── Temperature Trend ────── -->
                                        <Label Text="Temperature Trend"
                                               Style="{StaticResource SectionHead}" />

                                        <Border Style="{StaticResource Card}" Padding="12,14">
                                            <chart:SfCartesianChart HeightRequest="185"
                                                                     BackgroundColor="Transparent"
                                                                     EnableSideBySideSeriesPlacement="False">

                                                <chart:SfCartesianChart.XAxes>
                                                    <chart:CategoryAxis ShowMajorGridLines="False"
                                                                         EdgeLabelsDrawingMode="Center">
                                                        <chart:CategoryAxis.LabelStyle>
                                                            <chart:ChartAxisLabelStyle
                                                                TextColor="#608FA8C0"
                                                                FontSize="9" />
                                                        </chart:CategoryAxis.LabelStyle>
                                                        <chart:CategoryAxis.AxisLineStyle>
                                                            <chart:ChartLineStyle Stroke="#15FFFFFF" StrokeWidth="1" />
                                                        </chart:CategoryAxis.AxisLineStyle>
                                                    </chart:CategoryAxis>
                                                </chart:SfCartesianChart.XAxes>

                                                <chart:SfCartesianChart.YAxes>
                                                    <chart:NumericalAxis IsVisible="False"
                                                                          ShowMajorGridLines="True">
                                                        <chart:NumericalAxis.MajorGridLineStyle>
                                                            <chart:ChartLineStyle Stroke="#08FFFFFF" StrokeWidth="1" />
                                                        </chart:NumericalAxis.MajorGridLineStyle>
                                                        <chart:NumericalAxis.AxisLineStyle>
                                                            <chart:ChartLineStyle Stroke="Transparent" StrokeWidth="0" />
                                                        </chart:NumericalAxis.AxisLineStyle>
                                                    </chart:NumericalAxis>
                                                </chart:SfCartesianChart.YAxes>

                                                <!-- Area fill under line -->
                                                <chart:SplineAreaSeries
                                                    ItemsSource="{Binding HourlyForecasts}"
                                                    XBindingPath="TimeLabel"
                                                    YBindingPath="Temperature"
                                                    EnableAnimation="True"
                                                    Opacity="0.25">
                                                    <chart:SplineAreaSeries.Fill>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#38BDF8" Offset="0" />
                                                            <GradientStop Color="Transparent" Offset="1" />
                                                        </LinearGradientBrush>
                                                    </chart:SplineAreaSeries.Fill>
                                                </chart:SplineAreaSeries>

                                                <!-- Spline line + labels -->
                                                <chart:SplineSeries
                                                    ItemsSource="{Binding HourlyForecasts}"
                                                    XBindingPath="TimeLabel"
                                                    YBindingPath="Temperature"
                                                    EnableAnimation="True"
                                                    StrokeWidth="2.5"
                                                    ShowMarkers="True"
                                                    ShowDataLabels="True">
                                                    <chart:SplineSeries.MarkerSettings>
                                                        <chart:ChartMarkerSettings Type="Circle"
                                                                                    Width="7" Height="7"
                                                                                    Fill="#38BDF8"
                                                                                    Stroke="#0B1C2D"
                                                                                    StrokeWidth="1.5" />
                                                    </chart:SplineSeries.MarkerSettings>
                                                    <chart:SplineSeries.DataLabelSettings>
                                                        <chart:CartesianDataLabelSettings UseSeriesPalette="False">
                                                            <chart:CartesianDataLabelSettings.LabelStyle>
                                                                <chart:ChartDataLabelStyle
                                                                    TextColor="#F0F8FF"
                                                                    FontSize="10"
                                                                    FontAttributes="Bold"
                                                                    LabelPadding="4" />
                                                            </chart:CartesianDataLabelSettings.LabelStyle>
                                                        </chart:CartesianDataLabelSettings>
                                                    </chart:SplineSeries.DataLabelSettings>
                                                </chart:SplineSeries>

                                            </chart:SfCartesianChart>
                                        </Border>

                                        <!-- ────── Next Hours ────── -->
                                        <Label Text="Next Hours"
                                               Style="{StaticResource SectionHead}" />

                                        <listview:SfListView
                                            ItemsSource="{Binding HourlyForecasts}"
                                            Orientation="Horizontal"
                                            ItemSize="78"
                                            HeightRequest="118"
                                            Margin="20,0,20,0"
                                            SelectionMode="None">
                                            <listview:SfListView.ItemTemplate>
                                                <DataTemplate x:DataType="models:HourlyForecast">
                                                    <Border Style="{StaticResource HourlyCard}">
                                                        <VerticalStackLayout Spacing="4"
                                                                              HorizontalOptions="Center"
                                                                              WidthRequest="56">
                                                            <Label Text="{Binding TimeLabel}"
                                                                   TextColor="{StaticResource TextTertiary}"
                                                                   FontSize="10"
                                                                   HorizontalTextAlignment="Center" />
                                                            <Label Text="{Binding WeatherEmoji}"
                                                                   FontSize="22"
                                                                   HorizontalTextAlignment="Center" />
                                                            <Label Text="{Binding TempDisplay}"
                                                                   TextColor="{StaticResource TextPrimary}"
                                                                   FontSize="14" FontAttributes="Bold"
                                                                   HorizontalTextAlignment="Center" />
                                                            <Label Text="{Binding PrecipDisplay}"
                                                                   TextColor="{StaticResource Cyan}"
                                                                   FontSize="10"
                                                                   HorizontalTextAlignment="Center" />
                                                        </VerticalStackLayout>
                                                    </Border>
                                                </DataTemplate>
                                            </listview:SfListView.ItemTemplate>
                                        </listview:SfListView>

                                        <!-- ────── Atmosphere (Gauges) ────── -->
                                        <Label Text="Atmosphere"
                                               Style="{StaticResource SectionHead}" />

                                        <Border Style="{StaticResource Card}">
                                            <Grid ColumnDefinitions="*,1,*" ColumnSpacing="0">

                                                <!-- Humidity radial -->
                                                <VerticalStackLayout Grid.Column="0" Spacing="6"
                                                                      HorizontalOptions="Center">
                                                    <gauge:SfRadialGauge HeightRequest="128" WidthRequest="128" BackgroundColor="Transparent"
                                                                          HorizontalOptions="Center">
                                                        <gauge:SfRadialGauge.Axes>
                                                            <gauge:RadialAxis Minimum="0" Maximum="100"
                                                                               ShowLabels="False" ShowTicks="False">
                                                                <gauge:RadialAxis.Ranges>
                                                                    <gauge:RadialRange StartValue="0"
                                                                                       EndValue="{Binding Humidity}"
                                                                                       StartWidth="10" EndWidth="10"
                                                                                       Fill="{StaticResource HumidTeal}" />
                                                                </gauge:RadialAxis.Ranges>
                                                                <gauge:RadialAxis.Annotations>
                                                                    <gauge:GaugeAnnotation PositionFactor="0"
                                                                                            HorizontalAlignment="Center"
                                                                                            VerticalAlignment="Center">
                                                                        <gauge:GaugeAnnotation.Content>
                                                                            <VerticalStackLayout Spacing="0" HorizontalOptions="Center">
                                                                                <Label Text="💧" FontSize="16"
                                                                                       HorizontalTextAlignment="Center" />
                                                                                <Label Text="{Binding HumidityDisplay}"
                                                                                       TextColor="{StaticResource HumidTeal}"
                                                                                       FontSize="15" FontAttributes="Bold"
                                                                                       HorizontalTextAlignment="Center" />
                                                                            </VerticalStackLayout>
                                                                        </gauge:GaugeAnnotation.Content>
                                                                    </gauge:GaugeAnnotation>
                                                                </gauge:RadialAxis.Annotations>
                                                            </gauge:RadialAxis>
                                                        </gauge:SfRadialGauge.Axes>
                                                    </gauge:SfRadialGauge>
                                                    <Label Text="Humidity"
                                                           TextColor="{StaticResource TextTertiary}"
                                                           FontSize="11"
                                                           HorizontalTextAlignment="Center" />
                                                </VerticalStackLayout>

                                                <!-- Divider line -->
                                                <BoxView Grid.Column="1" Color="{StaticResource GlassBorder}"
                                                         WidthRequest="1" HeightRequest="90"
                                                         VerticalOptions="Center" />

                                                <!-- Wind radial -->
                                                <VerticalStackLayout Grid.Column="2" Spacing="6"
                                                                      HorizontalOptions="Center">
                                                    <gauge:SfRadialGauge HeightRequest="128" WidthRequest="128" BackgroundColor="Transparent"
                                                                          HorizontalOptions="Center">
                                                        <gauge:SfRadialGauge.Axes>
                                                            <gauge:RadialAxis Minimum="0" Maximum="40"
                                                                               ShowLabels="False" ShowTicks="False">
                                                                <gauge:RadialAxis.Ranges>
                                                                    <gauge:RadialRange StartValue="0"
                                                                                       EndValue="{Binding WindSpeed}"
                                                                                       StartWidth="10" EndWidth="10"
                                                                                       Fill="{StaticResource WindPurple}" />
                                                                </gauge:RadialAxis.Ranges>
                                                                <gauge:RadialAxis.Annotations>
                                                                    <gauge:GaugeAnnotation PositionFactor="0"
                                                                                            HorizontalAlignment="Center"
                                                                                            VerticalAlignment="Center">
                                                                        <gauge:GaugeAnnotation.Content>
                                                                            <VerticalStackLayout Spacing="0" HorizontalOptions="Center">
                                                                                <Label Text="💨" FontSize="16"
                                                                                       HorizontalTextAlignment="Center" />
                                                                                <Label Text="{Binding WindSpeedDisplay}"
                                                                                       TextColor="{StaticResource WindPurple}"
                                                                                       FontSize="14" FontAttributes="Bold"
                                                                                       HorizontalTextAlignment="Center" />
                                                                            </VerticalStackLayout>
                                                                        </gauge:GaugeAnnotation.Content>
                                                                    </gauge:GaugeAnnotation>
                                                                </gauge:RadialAxis.Annotations>
                                                            </gauge:RadialAxis>
                                                        </gauge:SfRadialGauge.Axes>
                                                    </gauge:SfRadialGauge>
                                                    <Label Text="Wind Speed"
                                                           TextColor="{StaticResource TextTertiary}"
                                                           FontSize="11"
                                                           HorizontalTextAlignment="Center" />
                                                </VerticalStackLayout>

                                            </Grid>
                                        </Border>

                                        <!-- ────── Today's Range ────── -->
                                        <Label Text="Today's Range"
                                               Style="{StaticResource SectionHead}" />

                                        <Border Style="{StaticResource Card}">
                                            <VerticalStackLayout Spacing="10">
                                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                                    <Label Grid.Column="0"
                                                           Text="{Binding LowTempDisplay}"
                                                           TextColor="{StaticResource LowBlue}"
                                                           FontSize="13" FontAttributes="Bold"
                                                           VerticalOptions="Center" />
                                                    <VerticalStackLayout Grid.Column="1" Spacing="4"
                                                                          VerticalOptions="Center">
                                                        <Label Text="{Binding CurrentTempDisplay}"
                                                               TextColor="{StaticResource TextSecondary}"
                                                               FontSize="11"
                                                               HorizontalTextAlignment="Center" />
                                                        <progressbar:SfLinearProgressBar
                                                            Progress="{Binding TempProgressValue}"
                                                            Minimum="0" Maximum="100"
                                                            HeightRequest="6"
                                                            ProgressCornerRadius="3"
                                                            TrackCornerRadius="3"
                                                            AnimationDuration="900" />
                                                    </VerticalStackLayout>
                                                    <Label Grid.Column="2"
                                                           Text="{Binding HighTempDisplay}"
                                                           TextColor="{StaticResource HighRed}"
                                                           FontSize="13" FontAttributes="Bold"
                                                           VerticalOptions="Center" />
                                                </Grid>
                                            </VerticalStackLayout>
                                        </Border>

                                        <!-- Bottom safe-area spacer -->
                                        <BoxView HeightRequest="32" Color="Transparent" />

                                    </VerticalStackLayout>

                                </VerticalStackLayout>
                            </ScrollView>

                        </ptr:SfPullToRefresh.PullableContent>
                    </ptr:SfPullToRefresh>
                </tabview:SfTabItem.Content>
            </tabview:SfTabItem>

            <!-- ══════════════════════════════  5 DAYS TAB  ══════════════════════════════ -->
            <tabview:SfTabItem Header="  Next 5 Days  "
                               TextColor="{StaticResource Cyan}"
                               FontSize="13"
                               FontAttributes="Bold">
                <tabview:SfTabItem.Content>
                    <ScrollView>
                        <VerticalStackLayout Spacing="0">

                            <!-- ────── Weekly Column Chart ────── -->
                            <Label Text="Weekly Overview"
                                   Style="{StaticResource SectionHead}" />

                            <Border Style="{StaticResource Card}" Padding="12,14">
                                <chart:SfCartesianChart HeightRequest="200" BackgroundColor="Transparent">

                                    <chart:SfCartesianChart.XAxes>
                                        <chart:CategoryAxis ShowMajorGridLines="False">
                                            <chart:CategoryAxis.LabelStyle>
                                                <chart:ChartAxisLabelStyle TextColor="#608FA8C0" FontSize="10" />
                                            </chart:CategoryAxis.LabelStyle>
                                            <chart:CategoryAxis.AxisLineStyle>
                                                <chart:ChartLineStyle Stroke="#15FFFFFF" StrokeWidth="1" />
                                            </chart:CategoryAxis.AxisLineStyle>
                                        </chart:CategoryAxis>
                                    </chart:SfCartesianChart.XAxes>

                                    <chart:SfCartesianChart.YAxes>
                                        <chart:NumericalAxis IsVisible="False" ShowMajorGridLines="True">
                                            <chart:NumericalAxis.MajorGridLineStyle>
                                                <chart:ChartLineStyle Stroke="#08FFFFFF" StrokeWidth="1" />
                                            </chart:NumericalAxis.MajorGridLineStyle>
                                            <chart:NumericalAxis.AxisLineStyle>
                                                <chart:ChartLineStyle Stroke="Transparent" StrokeWidth="0" />
                                            </chart:NumericalAxis.AxisLineStyle>
                                        </chart:NumericalAxis>
                                    </chart:SfCartesianChart.YAxes>

                                    <chart:ColumnSeries
                                        ItemsSource="{Binding DailyForecasts}"
                                        XBindingPath="DayName"
                                        YBindingPath="AvgTemperature"
                                        EnableAnimation="True"
                                        CornerRadius="8"
                                        ShowDataLabels="True">
                                        <chart:ColumnSeries.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#60A5FA" Offset="0" />
                                                <GradientStop Color="#38BDF8" Offset="1" />
                                            </LinearGradientBrush>
                                        </chart:ColumnSeries.Fill>
                                        <chart:ColumnSeries.DataLabelSettings>
                                            <chart:CartesianDataLabelSettings UseSeriesPalette="False">
                                                <chart:CartesianDataLabelSettings.LabelStyle>
                                                    <chart:ChartDataLabelStyle
                                                        TextColor="#F0F8FF"
                                                        FontSize="10" FontAttributes="Bold" />
                                                </chart:CartesianDataLabelSettings.LabelStyle>
                                            </chart:CartesianDataLabelSettings>
                                        </chart:ColumnSeries.DataLabelSettings>
                                    </chart:ColumnSeries>

                                </chart:SfCartesianChart>
                            </Border>

                            <!-- ────── 5-Day Forecast Rows ────── -->
                            <Label Text="5-Day Forecast"
                                   Style="{StaticResource SectionHead}" />

                            <VerticalStackLayout Margin="20,0,20,0" Spacing="10"
                                                  BindableLayout.ItemsSource="{Binding DailyForecasts}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:DailyForecast">

                                        <badge:SfBadgeView HorizontalOptions="Fill"
                                                            BadgeText="{Binding BadgeText}">
                                            <badge:SfBadgeView.BadgeSettings>
                                                <badge:BadgeSettings
                                                    Background="#F87171"
                                                    TextColor="White"
                                                    Position="TopRight"
                                                    FontSize="9"
                                                    IsVisible="{Binding IsHottestDay}"
                                                    Offset="-8,-6" />
                                            </badge:SfBadgeView.BadgeSettings>

                                            <Border Style="{StaticResource DayCard}">
                                                <Grid ColumnDefinitions="48,*,Auto" ColumnSpacing="14">

                                                    <!-- Emoji in pill -->
                                                    <Border Grid.Column="0"
                                                            BackgroundColor="{StaticResource GlassBgStrong}"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 14"
                                                            WidthRequest="48" HeightRequest="48"
                                                            HorizontalOptions="Center"
                                                            VerticalOptions="Center">
                                                        <Label Text="{Binding WeatherEmoji}"
                                                               FontSize="26"
                                                               HorizontalOptions="Center"
                                                               VerticalOptions="Center" />
                                                    </Border>

                                                    <!-- Day name + description + date -->
                                                    <VerticalStackLayout Grid.Column="1" Spacing="2"
                                                                          VerticalOptions="Center">
                                                        <Label Text="{Binding DayName}"
                                                               TextColor="{StaticResource TextPrimary}"
                                                               FontSize="15" FontAttributes="Bold" />
                                                        <Label Text="{Binding Description}"
                                                               TextColor="{StaticResource TextSecondary}"
                                                               FontSize="12" />
                                                        <Label Text="{Binding DateLabel}"
                                                               TextColor="{StaticResource TextTertiary}"
                                                               FontSize="11" />
                                                    </VerticalStackLayout>

                                                    <!-- High / Low -->
                                                    <VerticalStackLayout Grid.Column="2" Spacing="4"
                                                                          VerticalOptions="Center"
                                                                          HorizontalOptions="End">
                                                        <Label Text="{Binding MaxTemperature, StringFormat='{0:F0}°'}"
                                                               TextColor="{StaticResource HighRed}"
                                                               FontSize="16" FontAttributes="Bold"
                                                               HorizontalTextAlignment="End" />
                                                        <Label Text="{Binding MinTemperature, StringFormat='{0:F0}°'}"
                                                               TextColor="{StaticResource LowBlue}"
                                                               FontSize="13"
                                                               HorizontalTextAlignment="End" />
                                                    </VerticalStackLayout>

                                                </Grid>
                                            </Border>
                                        </badge:SfBadgeView>

                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                            <BoxView HeightRequest="32" Color="Transparent" />

                        </VerticalStackLayout>
                    </ScrollView>
                </tabview:SfTabItem.Content>
            </tabview:SfTabItem>

        </tabview:SfTabView>

        <!-- ═══════════════════════════  LOADING OVERLAY  ═══════════════════════════════ -->
        <Grid IsVisible="{Binding IsLoading}"
              BackgroundColor="{StaticResource Overlay}">
            <VerticalStackLayout HorizontalOptions="Center"
                                  VerticalOptions="Center"
                                  Spacing="16">
                <badge:SfBusyIndicator
                    IsRunning="{Binding IsLoading}"
                    AnimationType="CircularMaterial"
                    IndicatorColor="{StaticResource Cyan}"
                    HeightRequest="44"
                    WidthRequest="44" />
                <Label Text="Loading weather…"
                       TextColor="{StaticResource TextSecondary}"
                       FontSize="13"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>
