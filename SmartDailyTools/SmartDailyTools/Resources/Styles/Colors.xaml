<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ── Brand ──────────────────────────────────────────────────────── -->
    <Color x:Key="BrandPrimary">#4A6CF7</Color>
    <Color x:Key="BrandSecondary">#7C3AED</Color>
    <Color x:Key="BrandAccent">#06B6D4</Color>

    <!-- ── Semantic ────────────────────────────────────────────────────── -->
    <Color x:Key="Success">#22C55E</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="Danger">#EF4444</Color>
    <Color x:Key="Info">#3B82F6</Color>

    <!-- ── Backgrounds ─────────────────────────────────────────────────── -->
    <Color x:Key="PageBgLight">#F5F7FA</Color>
    <Color x:Key="PageBgDark">#0F172A</Color>
    <Color x:Key="CardBgLight">#FFFFFF</Color>
    <Color x:Key="CardBgDark">#1E293B</Color>
    <Color x:Key="StatCardBgLight">#F8FAFC</Color>
    <Color x:Key="StatCardBgDark">#0F172A</Color>

    <!-- ── Text ─────────────────────────────────────────────────────────── -->
    <Color x:Key="TextPrimaryLight">#1E293B</Color>
    <Color x:Key="TextPrimaryDark">#F1F5F9</Color>
    <Color x:Key="TextSecondaryLight">#64748B</Color>
    <Color x:Key="TextSecondaryDark">#94A3B8</Color>

    <!-- ── Border ──────────────────────────────────────────────────────── -->
    <Color x:Key="BorderLight">#E2E8F0</Color>
    <Color x:Key="BorderDark">#334155</Color>

    <!-- ── Compatibility aliases ───────────────────────────────────────── -->
    <Color x:Key="Primary">#4A6CF7</Color>
    <Color x:Key="PrimaryDark">#6A3DE8</Color>
    <Color x:Key="PrimaryDarkText">#242424</Color>
    <Color x:Key="Secondary">#EEF2FF</Color>
    <Color x:Key="SecondaryDarkText">#9880e5</Color>
    <Color x:Key="Tertiary">#7C3AED</Color>
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>
    <Color x:Key="Gray100">#F1F5F9</Color>
    <Color x:Key="Gray200">#E2E8F0</Color>
    <Color x:Key="Gray300">#CBD5E1</Color>
    <Color x:Key="Gray400">#94A3B8</Color>
    <Color x:Key="Gray500">#64748B</Color>
    <Color x:Key="Gray600">#475569</Color>
    <Color x:Key="Gray900">#1E293B</Color>
    <Color x:Key="Gray950">#0F172A</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource BrandPrimary}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}" />
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}" />
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}" />
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}" />
    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}" />
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}" />
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}" />
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}" />
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}" />
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}" />
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}" />
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}" />

</ResourceDictionary>
