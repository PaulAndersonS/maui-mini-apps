<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SmartDailyTools.Views.GstPage"
    x:Name="ThisPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:SmartDailyTools.ViewModels"
    xmlns:inputs="clr-namespace:Syncfusion.Maui.Inputs;assembly=Syncfusion.Maui.Inputs"
    xmlns:dataGrid="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid"
    xmlns:charts="clr-namespace:Syncfusion.Maui.Charts;assembly=Syncfusion.Maui.Charts"
    xmlns:tabView="clr-namespace:Syncfusion.Maui.TabView;assembly=Syncfusion.Maui.TabView"
    xmlns:shimmer="clr-namespace:Syncfusion.Maui.Shimmer;assembly=Syncfusion.Maui.Core"
    Title="{Binding Title}"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{AppThemeBinding Light=#F5F7FA, Dark=#0F172A}">

    <Grid RowDefinitions="Auto,*">

        <!-- Gradient Header -->
        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#8B5CF6" Offset="0" />
                    <GradientStop Color="#7C3AED" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>
            <Grid Padding="8,48,16,20" ColumnDefinitions="Auto,Auto,*">
                <Button Grid.Column="0" Text="←" TextColor="White" BackgroundColor="Transparent"
                    FontSize="22" WidthRequest="44" HeightRequest="44"
                    Command="{Binding GoBackCommand}" />
                <Label Grid.Column="1" Text="🧾" FontSize="28" VerticalOptions="Center" Margin="4,0,8,0" />
                <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="2">
                    <Label Text="GST Calculator" FontSize="20" FontAttributes="Bold" TextColor="White" />
                    <Label Text="Calculate GST amounts" FontSize="12" TextColor="#FFFFFFCC" />
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <tabView:SfTabView
            Grid.Row="1"
            TabWidthMode="SizeToContent"
            TabBarBackground="{AppThemeBinding Light=White, Dark=#1E293B}"
            IndicatorBackground="#8B5CF6">

        <tabView:SfTabItem Header="Calculator">
            <shimmer:SfShimmer IsActive="{Binding IsLoading}" Type="Article">
                <ScrollView>
                    <VerticalStackLayout Padding="16" Spacing="16">

                        <Border Style="{StaticResource CardStyle}">
                            <VerticalStackLayout Spacing="14">
                                <Label Text="GST Details" Style="{StaticResource SectionHeaderStyle}" />

                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Base Amount (₹)" Style="{StaticResource InputLabelStyle}" />
                                    <inputs:SfNumericEntry Value="{Binding BaseAmount, Mode=TwoWay}" Minimum="0" Maximum="100000000" Placeholder="0.00" HeightRequest="48" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="4">
                                    <Label Text="GST Rate (%)" Style="{StaticResource InputLabelStyle}" />
                                    <inputs:SfComboBox
                                        ItemsSource="{Binding GstRates}"
                                        SelectedItem="{Binding SelectedGstRate, Mode=TwoWay}"
                                        IsEditable="True"
                                        HeightRequest="48" />
                                </VerticalStackLayout>

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,4,0,0">
                                    <Button Grid.Column="0" Text="Calculate GST" Command="{Binding CalculateCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                                    <Button Grid.Column="1" Text="Reset" Command="{Binding ResetCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" IsVisible="{Binding HasResult}">
                            <VerticalStackLayout Spacing="12">
                                <Label Text="GST Breakdown" Style="{StaticResource SectionHeaderStyle}" />
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                    <Border Grid.Column="0" Style="{StaticResource StatCardStyle}">
                                        <VerticalStackLayout HorizontalOptions="Center">
                                            <Label Text="{Binding GstAmount}" FontSize="22" FontAttributes="Bold" TextColor="#8B5CF6" HorizontalOptions="Center" />
                                            <Label Text="GST Amount" FontSize="11" TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" HorizontalOptions="Center" />
                                        </VerticalStackLayout>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource StatCardStyle}">
                                        <VerticalStackLayout HorizontalOptions="Center">
                                            <Label Text="{Binding TotalAmount}" FontSize="22" FontAttributes="Bold" TextColor="#4A6CF7" HorizontalOptions="Center" />
                                            <Label Text="Total with GST" FontSize="11" TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" HorizontalOptions="Center" />
                                        </VerticalStackLayout>
                                    </Border>
                                </Grid>

                                <!-- Circular Chart: Base vs GST -->
                                <charts:SfCircularChart HeightRequest="200">
                                    <charts:SfCircularChart.Title>
                                        <Label Text="Base vs GST" HorizontalOptions="Center" FontSize="12" TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                                    </charts:SfCircularChart.Title>
                                    <charts:PieSeries
                                        ItemsSource="{Binding GstBreakdownData}"
                                        XBindingPath="Label"
                                        YBindingPath="Value"
                                        EnableAnimation="True"
                                        ShowDataLabels="True"
                                        Radius="0.8">
                                        <charts:PieSeries.PaletteBrushes>
                                            <SolidColorBrush Color="#4A6CF7" />
                                            <SolidColorBrush Color="#8B5CF6" />
                                        </charts:PieSeries.PaletteBrushes>
                                    </charts:PieSeries>
                                </charts:SfCircularChart>

                                <Button Text="Save to History" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                            </VerticalStackLayout>
                        </Border>

                    </VerticalStackLayout>
                </ScrollView>
            </shimmer:SfShimmer>
        </tabView:SfTabItem>

        <tabView:SfTabItem Header="History">
            <Grid Padding="16">
                <dataGrid:SfDataGrid
                    ItemsSource="{Binding History}"
                    AutoGenerateColumnsMode="None"
                    ColumnWidthMode="Fill"
                    GridLinesVisibility="Both"
                    HeaderRowHeight="44"
                    RowHeight="52">
                    <dataGrid:SfDataGrid.Columns>
                        <dataGrid:DataGridTextColumn HeaderText="Date" MappingName="FormattedDate" Width="150" />
                        <dataGrid:DataGridTextColumn HeaderText="Summary" MappingName="Summary" Width="220" />
                        <dataGrid:DataGridTemplateColumn HeaderText="" Width="56">
                            <dataGrid:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Text="🗑" FontSize="16" BackgroundColor="Transparent"
                                        Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.DeleteHistoryCommand}"
                                        CommandParameter="{Binding .}" />
                                </DataTemplate>
                            </dataGrid:DataGridTemplateColumn.CellTemplate>
                        </dataGrid:DataGridTemplateColumn>
                    </dataGrid:SfDataGrid.Columns>
                </dataGrid:SfDataGrid>
            </Grid>
        </tabView:SfTabItem>

    </tabView:SfTabView>

    </Grid>
</ContentPage>
