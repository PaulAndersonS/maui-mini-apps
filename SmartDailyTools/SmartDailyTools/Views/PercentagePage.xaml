<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SmartDailyTools.Views.PercentagePage"
    x:Name="ThisPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:SmartDailyTools.ViewModels"
    xmlns:inputs="clr-namespace:Syncfusion.Maui.Inputs;assembly=Syncfusion.Maui.Inputs"
    xmlns:dataGrid="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid"
    xmlns:tabView="clr-namespace:Syncfusion.Maui.TabView;assembly=Syncfusion.Maui.TabView"
    xmlns:shimmer="clr-namespace:Syncfusion.Maui.Shimmer;assembly=Syncfusion.Maui.Core"
    Title="{Binding Title}"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{AppThemeBinding Light=#F5F7FA, Dark=#0F172A}">

    <Grid RowDefinitions="Auto,*">

        <!-- Gradient Header -->
        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#EF4444" Offset="0" />
                    <GradientStop Color="#DC2626" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>
            <Grid Padding="8,48,16,20" ColumnDefinitions="Auto,Auto,*">
                <Button Grid.Column="0" Text="←" TextColor="White" BackgroundColor="Transparent"
                    FontSize="22" WidthRequest="44" HeightRequest="44"
                    Command="{Binding GoBackCommand}" />
                <Label Grid.Column="1" Text="📊" FontSize="28" VerticalOptions="Center" Margin="4,0,8,0" />
                <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="2">
                    <Label Text="Percentage Calculator" FontSize="20" FontAttributes="Bold" TextColor="White" />
                    <Label Text="Quick percentage calculations" FontSize="12" TextColor="#FFFFFFCC" />
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <tabView:SfTabView
            Grid.Row="1"
            TabWidthMode="SizeToContent"
            TabBarBackground="{AppThemeBinding Light=White, Dark=#1E293B}"
            IndicatorBackground="#EF4444">

        <tabView:SfTabItem Header="Calculator">
            <shimmer:SfShimmer IsActive="{Binding IsLoading}" Type="Article">
                <ScrollView>
                    <VerticalStackLayout Padding="16" Spacing="16">

                        <Border Style="{StaticResource CardStyle}">
                            <VerticalStackLayout Spacing="14">
                                <Label Text="Select Mode" Style="{StaticResource SectionHeaderStyle}" />
                                <inputs:SfComboBox
                                    ItemsSource="{Binding Modes}"
                                    SelectedItem="{Binding SelectedMode, Mode=TwoWay}"
                                    IsEditable="False"
                                    HeightRequest="48" />

                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding LabelA}" Style="{StaticResource InputLabelStyle}" />
                                    <inputs:SfNumericEntry Value="{Binding InputA, Mode=TwoWay}" Minimum="0" Placeholder="0" HeightRequest="48" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding LabelB}" Style="{StaticResource InputLabelStyle}" />
                                    <inputs:SfNumericEntry Value="{Binding InputB, Mode=TwoWay}" Minimum="0" Placeholder="0" HeightRequest="48" />
                                </VerticalStackLayout>

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,4,0,0">
                                    <Button Grid.Column="0" Text="Calculate" Command="{Binding CalculateCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                                    <Button Grid.Column="1" Text="Reset" Command="{Binding ResetCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" IsVisible="{Binding HasResult}">
                            <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                                <Label Text="Result" Style="{StaticResource SectionHeaderStyle}" />
                                <Label Text="{Binding Result}" FontSize="48" FontAttributes="Bold" TextColor="#EF4444" HorizontalOptions="Center" />
                                <Button Text="Save to History" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                            </VerticalStackLayout>
                        </Border>

                    </VerticalStackLayout>
                </ScrollView>
            </shimmer:SfShimmer>
        </tabView:SfTabItem>

        <tabView:SfTabItem Header="History">
            <Grid Padding="16">
                <dataGrid:SfDataGrid
                    ItemsSource="{Binding History}"
                    AutoGenerateColumnsMode="None"
                    ColumnWidthMode="Fill"
                    GridLinesVisibility="Both"
                    HeaderRowHeight="44"
                    RowHeight="52">
                    <dataGrid:SfDataGrid.Columns>
                        <dataGrid:DataGridTextColumn HeaderText="Date" MappingName="FormattedDate" Width="150" />
                        <dataGrid:DataGridTextColumn HeaderText="Mode" MappingName="Mode" Width="160" />
                        <dataGrid:DataGridTextColumn HeaderText="Result" MappingName="Summary" Width="110" />
                        <dataGrid:DataGridTemplateColumn HeaderText="" Width="56">
                            <dataGrid:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Text="🗑" FontSize="16" BackgroundColor="Transparent"
                                        Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.DeleteHistoryCommand}"
                                        CommandParameter="{Binding .}" />
                                </DataTemplate>
                            </dataGrid:DataGridTemplateColumn.CellTemplate>
                        </dataGrid:DataGridTemplateColumn>
                    </dataGrid:SfDataGrid.Columns>
                </dataGrid:SfDataGrid>
            </Grid>
        </tabView:SfTabItem>

    </tabView:SfTabView>

    </Grid>
</ContentPage>
