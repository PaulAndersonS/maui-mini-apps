<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SmartDailyTools.Views.QrPage"
    x:Name="ThisPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:SmartDailyTools.ViewModels"
    xmlns:dataGrid="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid"
    xmlns:tabView="clr-namespace:Syncfusion.Maui.TabView;assembly=Syncfusion.Maui.TabView"
    xmlns:shimmer="clr-namespace:Syncfusion.Maui.Shimmer;assembly=Syncfusion.Maui.Core"
    xmlns:barcode="clr-namespace:Syncfusion.Maui.Barcode;assembly=Syncfusion.Maui.Barcode"
    Title="{Binding Title}"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{AppThemeBinding Light=#F5F7FA, Dark=#0F172A}">

    <Grid RowDefinitions="Auto,*">

        <!-- Gradient Header -->
        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F97316" Offset="0" />
                    <GradientStop Color="#EA580C" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>
            <Grid Padding="8,48,16,20" ColumnDefinitions="Auto,Auto,*">
                <Button Grid.Column="0" Text="←" TextColor="White" BackgroundColor="Transparent"
                    FontSize="22" WidthRequest="44" HeightRequest="44"
                    Command="{Binding GoBackCommand}" />
                <Label Grid.Column="1" Text="📱" FontSize="28" VerticalOptions="Center" Margin="4,0,8,0" />
                <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="2">
                    <Label Text="QR Generator" FontSize="20" FontAttributes="Bold" TextColor="White" />
                    <Label Text="Generate QR codes instantly" FontSize="12" TextColor="#FFFFFFCC" />
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <tabView:SfTabView
            Grid.Row="1"
            TabWidthMode="SizeToContent"
            TabBarBackground="{AppThemeBinding Light=White, Dark=#1E293B}"
            IndicatorBackground="#F97316">

        <tabView:SfTabItem Header="Generator">
            <shimmer:SfShimmer IsActive="{Binding IsLoading}" Type="Article">
                <ScrollView>
                    <VerticalStackLayout Padding="16" Spacing="16">

                        <Border Style="{StaticResource CardStyle}">
                            <VerticalStackLayout Spacing="14">
                                <Label Text="Enter Text / URL" Style="{StaticResource SectionHeaderStyle}" />
                                <Border
                                    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1E293B}"
                                    Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="12,8">
                                    <Editor
                                        Text="{Binding InputText, Mode=TwoWay}"
                                        Placeholder="Enter text or URL to encode..."
                                        AutoSize="TextChanges"
                                        MinimumHeightRequest="80"
                                        MaxLength="500"
                                        FontSize="15"
                                        BackgroundColor="Transparent"
                                        TextColor="{AppThemeBinding Light=#1E293B, Dark=#F1F5F9}" />
                                </Border>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                    <Button Grid.Column="0" Text="Generate QR" Command="{Binding GenerateCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                                    <Button Grid.Column="1" Text="Reset" Command="{Binding ResetCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                        <!-- QR Code Display -->
                        <Border Style="{StaticResource CardStyle}" IsVisible="{Binding HasQr}">
                            <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                                <Label Text="Your QR Code" Style="{StaticResource SectionHeaderStyle}" HorizontalOptions="Center" />
                                <Border
                                    BackgroundColor="White"
                                    Padding="16"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12"
                                    HorizontalOptions="Center">
                                    <barcode:SfBarcodeGenerator
                                        Value="{Binding QrValue}"
                                        IsVisible="{Binding HasQr}"
                                        HeightRequest="220"
                                        WidthRequest="220"
                                        ShowText="False"
                                        BackgroundColor="White" >
                                        <barcode:SfBarcodeGenerator.Symbology>
                                            <barcode:QRCode />
                                        </barcode:SfBarcodeGenerator.Symbology>
                                    </barcode:SfBarcodeGenerator>
                                </Border>
                                <Button Text="Save to History" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                            </VerticalStackLayout>
                        </Border>

                    </VerticalStackLayout>
                </ScrollView>
            </shimmer:SfShimmer>
        </tabView:SfTabItem>

        <tabView:SfTabItem Header="History">
            <Grid Padding="16">
                <dataGrid:SfDataGrid
                    ItemsSource="{Binding History}"
                    AutoGenerateColumnsMode="None"
                    ColumnWidthMode="Fill"
                    GridLinesVisibility="Both"
                    HeaderRowHeight="44"
                    RowHeight="52">
                    <dataGrid:SfDataGrid.Columns>
                        <dataGrid:DataGridTextColumn HeaderText="Date" MappingName="FormattedDate" Width="150" />
                        <dataGrid:DataGridTextColumn HeaderText="Text" MappingName="Summary" Width="220" />
                        <dataGrid:DataGridTemplateColumn HeaderText="" Width="56">
                            <dataGrid:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Text="🗑" FontSize="16" BackgroundColor="Transparent"
                                        Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.DeleteHistoryCommand}"
                                        CommandParameter="{Binding .}" />
                                </DataTemplate>
                            </dataGrid:DataGridTemplateColumn.CellTemplate>
                        </dataGrid:DataGridTemplateColumn>
                    </dataGrid:SfDataGrid.Columns>
                </dataGrid:SfDataGrid>
            </Grid>
        </tabView:SfTabItem>

    </tabView:SfTabView>

    </Grid>
</ContentPage>
