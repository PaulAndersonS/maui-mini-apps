<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:datagrid="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid"
             x:Class="SmartExpense.Views.TransactionsPage">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{AppThemeBinding Light=#F1EEFF, Dark=#23264A}" Offset="0" />
                <GradientStop Color="{AppThemeBinding Light=#E4E9FF, Dark=#15172B}" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid RowDefinitions="Auto,Auto,*" Padding="16" RowSpacing="14">

            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Border HeightRequest="40" WidthRequest="40" StrokeThickness="0" BackgroundColor="#FF9E59" VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Label Text="☰" FontSize="18" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                    <Label Text="Transactions" FontSize="20" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#23264A, Dark=#F2F5FF}" />
                    <Label Text="Your spending history"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light=#6B6E8E, Dark=#9BA0CC}" />
                </VerticalStackLayout>
            </Grid>

            <!-- Filter + action card -->
            <Border Grid.Row="1" Padding="16" StrokeThickness="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="{AppThemeBinding Light=#FFFFFF, Dark=#20233E}" Offset="0" />
                        <GradientStop Color="{AppThemeBinding Light=#F8F6FF, Dark=#272A46}" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">

                    <!-- Month picker row -->
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Label Text="📅" FontSize="18" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Filter by month" FontSize="14" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#23264A, Dark=#F2F5FF}"
                               VerticalOptions="Center" />
                        <DatePicker Grid.Column="2"
                                    Date="{Binding FilterMonth}"
                                    Format="MMM yyyy"
                                    TextColor="{AppThemeBinding Light=#7A59FF, Dark=#A89BFF}"
                                    BackgroundColor="Transparent"
                                    VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light=#E0E0F0, Dark=#3A3D5E}" />

                    <!-- Action buttons -->
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <!-- Apply -->
                        <Border Padding="0" StrokeThickness="0" HeightRequest="40">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#7A59FF" Offset="0" />
                                    <GradientStop Color="#40A7FF" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Button Text="Apply" Command="{Binding LoadCommand}"
                                    BackgroundColor="Transparent" TextColor="White"
                                    FontAttributes="Bold" FontSize="14" />
                        </Border>

                        <!-- Edit -->
                        <Border Grid.Column="1" Padding="0" StrokeThickness="0" HeightRequest="40">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#39B5FF" Offset="0" />
                                    <GradientStop Color="#4967FF" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Button Text="✏ Edit" Command="{Binding EditSelectedCommand}"
                                    BackgroundColor="Transparent" TextColor="White"
                                    FontAttributes="Bold" FontSize="14" />
                        </Border>

                        <!-- Delete -->
                        <Border Grid.Column="2" Padding="0" StrokeThickness="0" HeightRequest="40">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF9E59" Offset="0" />
                                    <GradientStop Color="#F25B5B" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Button Text="🗑 Delete" Command="{Binding DeleteSelectedCommand}"
                                    BackgroundColor="Transparent" TextColor="White"
                                    FontAttributes="Bold" FontSize="14" />
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- DataGrid card - takes remaining space -->
            <Border Grid.Row="2" Padding="0" StrokeThickness="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="{AppThemeBinding Light=#FFFFFF, Dark=#20233E}" Offset="0" />
                        <GradientStop Color="{AppThemeBinding Light=#F8F6FF, Dark=#272A46}" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <datagrid:SfDataGrid ItemsSource="{Binding Transactions}"
                                     SelectionMode="Single"
                                     SelectedIndex="{Binding SelectedIndex}"
                                     SelectedRow="{Binding SelectedTransaction}"
                                     AllowFiltering="True"
                                     AutoGenerateColumnsMode="Reset"
                                     VerticalOptions="Fill" />
            </Border>

        </Grid>
    </Grid>
</ContentView>
