<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:input="clr-namespace:Syncfusion.Maui.Inputs;assembly=Syncfusion.Maui.Inputs"
             xmlns:core="clr-namespace:Syncfusion.Maui.Shimmer;assembly=Syncfusion.Maui.Core"
             xmlns:chart="clr-namespace:Syncfusion.Maui.Charts;assembly=Syncfusion.Maui.Charts"
             x:Class="SmartExpense.Views.DashboardPage">
    <Grid x:Name="DashboardRoot" BackgroundColor="{AppThemeBinding Light=#EDEAFF, Dark=#1A1D33}">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{AppThemeBinding Light=#F1EEFF, Dark=#23264A}" Offset="0" />
                <GradientStop Color="{AppThemeBinding Light=#E4E9FF, Dark=#15172B}" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView>
            <VerticalStackLayout Padding="16" Spacing="18">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                    <Border HeightRequest="34" WidthRequest="34" StrokeThickness="0" BackgroundColor="#55FFFFFF" VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="17" />
                        </Border.StrokeShape>
                        <Label Text="👤" HorizontalOptions="Center" VerticalOptions="Center" FontSize="16" />
                    </Border>

                    <Label Grid.Column="1"
                           Text="{Binding GreetingText}"
                           VerticalOptions="Center"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#23264A, Dark=#F2F5FF}" />

                    <input:SfComboBox Grid.Column="2"
                                      WidthRequest="128"
                                      HeightRequest="36"
                                      HorizontalOptions="End"
                                      VerticalOptions="Center"
                                      ItemsSource="{Binding MonthOptions}"
                                      SelectedItem="{Binding SelectedMonth}"
                                      Placeholder="Month" />

                    <Border Grid.Column="3" HeightRequest="34" WidthRequest="34" StrokeThickness="0"
                            BackgroundColor="#55FF5E6D" VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="17" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LogoutCommand}" />
                        </Border.GestureRecognizers>
                        <Label Text="⏻" FontSize="16" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                </Grid>

                <Border Padding="18" StrokeThickness="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#7A59FF" Offset="0" />
                            <GradientStop Color="#40A7FF" Offset="0.65" />
                            <GradientStop Color="#62D2FF" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Total Balance" TextColor="#E8F0FF" FontAttributes="Bold" FontSize="17" />
                        <Label Text="{Binding TotalBalanceText}" FontSize="39" FontAttributes="Bold" TextColor="{Binding BalanceColor}" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,4,0,0">
                            <Button Text="AI Summary" Command="{Binding ShowAISummaryCommand}" BackgroundColor="#44906BFF" TextColor="White" CornerRadius="16" FontAttributes="Bold" />
                            <Button Grid.Column="1" Text="Custom Reports" Command="{Binding NavigateToReportsCommand}" BackgroundColor="#55FFB252" TextColor="White" CornerRadius="16" FontAttributes="Bold" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Label Text="Summary" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#23264A, Dark=#F5F6FF}" />

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                    <Border Style="{StaticResource CardStyle}" Padding="10" StrokeThickness="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#3CD67F" Offset="0" />
                                <GradientStop Color="#24AE89" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Income" TextColor="White" FontAttributes="Bold" FontSize="14" />
                            <Label Text="{Binding TotalIncomeText}" TextColor="White" FontSize="22" FontAttributes="Bold" />
                            <Label Text="This Month" TextColor="#D9FFF0" FontSize="12" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="10" StrokeThickness="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF9E59" Offset="0" />
                                <GradientStop Color="#F25B5B" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Expenses" TextColor="White" FontAttributes="Bold" FontSize="14" />
                            <Label Text="{Binding TotalExpenseText}" TextColor="White" FontSize="22" FontAttributes="Bold" />
                            <Label Text="This Month" TextColor="#FFE9D8" FontSize="12" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="10" StrokeThickness="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#39B5FF" Offset="0" />
                                <GradientStop Color="#4967FF" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Savings" TextColor="White" FontAttributes="Bold" FontSize="14" />
                            <Label Text="{Binding SavingsText}" TextColor="White" FontSize="22" FontAttributes="Bold" />
                            <Label Text="{Binding SavingsPercentText, StringFormat='Saved {0}'}" TextColor="#DBE7FF" FontSize="12" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <core:SfShimmer IsActive="{Binding IsLoading}" IsVisible="{Binding IsLoading}" HeightRequest="120" />

                <Border Style="{StaticResource CardStyle}" Padding="14" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#20233E}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Monthly Overview" TextColor="{AppThemeBinding Light=#23264A, Dark=#F2F4FF}" FontAttributes="Bold" FontSize="16" />
                        <chart:SfCartesianChart HeightRequest="260">
                            <chart:SfCartesianChart.XAxes>
                                <chart:CategoryAxis ShowMajorGridLines="False" />
                            </chart:SfCartesianChart.XAxes>
                            <chart:SfCartesianChart.YAxes>
                                <chart:NumericalAxis ShowMajorGridLines="True" />
                            </chart:SfCartesianChart.YAxes>
                            <chart:SplineSeries ItemsSource="{Binding MonthlyTrends}" XBindingPath="Month" YBindingPath="Income" Label="Income" EnableAnimation="True" StrokeWidth="3" />
                            <chart:SplineSeries ItemsSource="{Binding MonthlyTrends}" XBindingPath="Month" YBindingPath="Expense" Label="Expense" EnableAnimation="True" StrokeWidth="3" />
                            <chart:SplineSeries ItemsSource="{Binding MonthlyTrends}" XBindingPath="Month" YBindingPath="Savings" Label="Savings" EnableAnimation="True" StrokeWidth="3" />
                        </chart:SfCartesianChart>

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" Padding="10,8" BackgroundColor="#2A2D4B">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding NavigateToAddCommand}" />
                            </Grid.GestureRecognizers>
                            <Border HeightRequest="30" WidthRequest="30" BackgroundColor="#944DFF" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="15" />
                                </Border.StrokeShape>
                                <Label Text="+" FontSize="20" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Grid.Column="1" Text="Add Transaction" VerticalOptions="Center" TextColor="White" FontAttributes="Bold" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Category Breakdown" Style="{StaticResource TitleLabelStyle}" FontSize="16" />
                        <Label Text="{Binding TotalExpenseText}" Style="{StaticResource AmountLabelStyle}" TextColor="#FF6A5E" />

                        <chart:SfCircularChart HeightRequest="260">
                            <chart:SfCircularChart.Legend>
                                <chart:ChartLegend />
                            </chart:SfCircularChart.Legend>
                            <chart:DoughnutSeries ItemsSource="{Binding CategoryBreakdown}"
                                                  XBindingPath="Category"
                                                  YBindingPath="Percentage"
                                                  ShowDataLabels="True"
                                                  EnableAnimation="True" />
                        </chart:SfCircularChart>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentView>
