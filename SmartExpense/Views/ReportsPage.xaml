<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartExpense.Views.ReportsPage">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{AppThemeBinding Light=#F1EEFF, Dark=#23264A}" Offset="0" />
                <GradientStop Color="{AppThemeBinding Light=#E4E9FF, Dark=#15172B}" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView>
            <VerticalStackLayout Padding="16,16,16,32" Spacing="18">

                <!-- Header -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                    <Border HeightRequest="40" WidthRequest="40" StrokeThickness="0" BackgroundColor="#3CD67F" VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Label Text="📊" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                        <Label Text="Reports" FontSize="20" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#23264A, Dark=#F2F5FF}" />
                        <Label Text="Monthly insights &amp; exports"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#6B6E8E, Dark=#9BA0CC}" />
                    </VerticalStackLayout>
                </Grid>

                <!-- Month selector card -->
                <Border Padding="18" StrokeThickness="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{AppThemeBinding Light=#FFFFFF, Dark=#20233E}" Offset="0" />
                            <GradientStop Color="{AppThemeBinding Light=#F8F6FF, Dark=#272A46}" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="14">
                        <Label Text="SELECT MONTH" FontSize="11" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#9B9FC0, Dark=#6B6E8E}" />
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Label Text="📅" FontSize="18" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="Reporting period" FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#23264A, Dark=#F2F5FF}"
                                   VerticalOptions="Center" />
                            <DatePicker Grid.Column="2"
                                        Date="{Binding SelectedMonth}"
                                        Format="MMM yyyy"
                                        TextColor="{AppThemeBinding Light=#7A59FF, Dark=#A89BFF}"
                                        BackgroundColor="Transparent"
                                        VerticalOptions="Center" />
                        </Grid>

                        <Border Padding="0" StrokeThickness="0" HeightRequest="46">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#7A59FF" Offset="0" />
                                    <GradientStop Color="#40A7FF" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Button Text="Load Monthly Summary" Command="{Binding LoadSummaryCommand}"
                                    BackgroundColor="Transparent" TextColor="White"
                                    FontAttributes="Bold" FontSize="15" />
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <!-- Summary breakdown card -->
                <Border Padding="18" StrokeThickness="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{AppThemeBinding Light=#FFFFFF, Dark=#20233E}" Offset="0" />
                            <GradientStop Color="{AppThemeBinding Light=#F8F6FF, Dark=#272A46}" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="14">
                        <Label Text="MONTHLY SUMMARY" FontSize="11" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#9B9FC0, Dark=#6B6E8E}" />

                        <!-- 3 stat mini-cards -->
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <!-- Income -->
                            <Border Padding="10,12" StrokeThickness="0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#3CD67F" Offset="0" />
                                        <GradientStop Color="#24AE89" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="↑ Income" FontSize="11" FontAttributes="Bold" TextColor="#D9FFF0" />
                                    <Label Text="{Binding SummaryIncomeText}" FontSize="14" FontAttributes="Bold" TextColor="White" LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>
                            </Border>
                            <!-- Expenses -->
                            <Border Grid.Column="1" Padding="10,12" StrokeThickness="0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FF9E59" Offset="0" />
                                        <GradientStop Color="#F25B5B" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="↓ Expense" FontSize="11" FontAttributes="Bold" TextColor="#FFE9D8" />
                                    <Label Text="{Binding SummaryExpenseText}" FontSize="14" FontAttributes="Bold" TextColor="White" LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>
                            </Border>
                            <!-- Net -->
                            <Border Grid.Column="2" Padding="10,12" StrokeThickness="0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#39B5FF" Offset="0" />
                                        <GradientStop Color="#4967FF" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="≡ Net" FontSize="11" FontAttributes="Bold" TextColor="#DBE7FF" />
                                    <Label Text="{Binding SummaryNetText}" FontSize="14" FontAttributes="Bold" TextColor="White" LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light=#E0E0F0, Dark=#3A3D5E}" />
                        <Label Text="{Binding MonthSummary}"
                               FontSize="14"
                               TextColor="{AppThemeBinding Light=#23264A, Dark=#F2F5FF}"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <!-- Export card -->
                <Border Padding="18" StrokeThickness="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{AppThemeBinding Light=#FFFFFF, Dark=#20233E}" Offset="0" />
                            <GradientStop Color="{AppThemeBinding Light=#F8F6FF, Dark=#272A46}" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="14">
                        <Label Text="EXPORT" FontSize="11" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#9B9FC0, Dark=#6B6E8E}" />
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Border HeightRequest="44" WidthRequest="44" StrokeThickness="0" BackgroundColor="#FF9E59">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="22" />
                                </Border.StrokeShape>
                                <Label Text="📄" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="Monthly PDF Report" FontSize="15" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#23264A, Dark=#F2F5FF}" />
                                <Label Text="Shareable summary of all transactions"
                                       FontSize="12" TextColor="{AppThemeBinding Light=#6B6E8E, Dark=#9BA0CC}" />
                            </VerticalStackLayout>
                        </Grid>

                        <Border Padding="0" StrokeThickness="0" HeightRequest="46">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF9E59" Offset="0" />
                                    <GradientStop Color="#F25B5B" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Button Text="Export to PDF" Command="{Binding ExportPdfCommand}"
                                    BackgroundColor="Transparent" TextColor="White"
                                    FontAttributes="Bold" FontSize="15" />
                        </Border>

                        <Label Text="{Binding LastReportPath}"
                               FontSize="11"
                               Opacity="0.65"
                               LineBreakMode="MiddleTruncation"
                               TextColor="{AppThemeBinding Light=#6B6E8E, Dark=#9BA0CC}" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentView>
