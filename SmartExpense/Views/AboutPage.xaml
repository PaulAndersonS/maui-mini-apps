<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartExpense.Views.AboutPage">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{AppThemeBinding Light=#F1EEFF, Dark=#23264A}" Offset="0" />
                <GradientStop Color="{AppThemeBinding Light=#E4E9FF, Dark=#15172B}" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView>
            <VerticalStackLayout Padding="16,16,16,32" Spacing="18">

                <!-- App hero card -->
                <Border Padding="24,28" StrokeThickness="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#7A59FF" Offset="0" />
                            <GradientStop Color="#40A7FF" Offset="0.65" />
                            <GradientStop Color="#62D2FF" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Border HeightRequest="72" WidthRequest="72" StrokeThickness="0"
                                BackgroundColor="#44FFFFFF" HorizontalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="36" />
                            </Border.StrokeShape>
                            <Label Text="💰" FontSize="36" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Text="SmartExpense" FontSize="26" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center" />
                        <Label Text="Your personal finance companion" FontSize="14"
                               TextColor="#D8EEFF" HorizontalOptions="Center" />
                        <Border Padding="14,6" StrokeThickness="0" BackgroundColor="#33FFFFFF"
                                HorizontalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Label Text="Version 1.0.0" FontSize="12" FontAttributes="Bold"
                                   TextColor="White" />
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <!-- About text card -->
                <Border Padding="18" StrokeThickness="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{AppThemeBinding Light=#FFFFFF, Dark=#20233E}" Offset="0" />
                            <GradientStop Color="{AppThemeBinding Light=#F8F6FF, Dark=#272A46}" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Label Text="ABOUT" FontSize="11" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#9B9FC0, Dark=#6B6E8E}" />
                        <Label Text="{Binding AboutText}" FontSize="15" LineBreakMode="WordWrap"
                               TextColor="{AppThemeBinding Light=#23264A, Dark=#F2F5FF}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Tech stack card -->
                <Border Padding="18" StrokeThickness="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{AppThemeBinding Light=#FFFFFF, Dark=#20233E}" Offset="0" />
                            <GradientStop Color="{AppThemeBinding Light=#F8F6FF, Dark=#272A46}" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="14">
                        <Label Text="BUILT WITH" FontSize="11" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#9B9FC0, Dark=#6B6E8E}" />

                        <!-- Row: .NET MAUI -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                            <Border HeightRequest="42" WidthRequest="42" StrokeThickness="0" BackgroundColor="#7A59FF">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                                <Label Text="🟣" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text=".NET MAUI" FontSize="15" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#23264A, Dark=#F2F5FF}" />
                                <Label Text="Cross-platform UI framework" FontSize="12"
                                       TextColor="{AppThemeBinding Light=#6B6E8E, Dark=#9BA0CC}" />
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light=#E0E0F0, Dark=#3A3D5E}" />

                        <!-- Row: Syncfusion -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                            <Border HeightRequest="42" WidthRequest="42" StrokeThickness="0" BackgroundColor="#3CD67F">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                                <Label Text="📦" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="Syncfusion" FontSize="15" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#23264A, Dark=#F2F5FF}" />
                                <Label Text="Charts, DataGrid, Inputs &amp; more" FontSize="12"
                                       TextColor="{AppThemeBinding Light=#6B6E8E, Dark=#9BA0CC}" />
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light=#E0E0F0, Dark=#3A3D5E}" />

                        <!-- Row: SQLite -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                            <Border HeightRequest="42" WidthRequest="42" StrokeThickness="0" BackgroundColor="#39B5FF">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                                <Label Text="🗃️" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="SQLite / EF Core" FontSize="15" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#23264A, Dark=#F2F5FF}" />
                                <Label Text="Local on-device data storage" FontSize="12"
                                       TextColor="{AppThemeBinding Light=#6B6E8E, Dark=#9BA0CC}" />
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light=#E0E0F0, Dark=#3A3D5E}" />

                        <!-- Row: MVVM -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                            <Border HeightRequest="42" WidthRequest="42" StrokeThickness="0" BackgroundColor="#FF9E59">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                                <Label Text="⚙️" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="MVVM Toolkit" FontSize="15" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#23264A, Dark=#F2F5FF}" />
                                <Label Text="Community Toolkit architecture" FontSize="12"
                                       TextColor="{AppThemeBinding Light=#6B6E8E, Dark=#9BA0CC}" />
                            </VerticalStackLayout>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentView>
