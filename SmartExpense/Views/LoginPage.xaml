<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartExpense.Views.LoginPage"
             NavigationPage.HasNavigationBar="False">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{AppThemeBinding Light=#F1EEFF, Dark=#23264A}" Offset="0" />
                <GradientStop Color="{AppThemeBinding Light=#E4E9FF, Dark=#15172B}" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView VerticalOptions="Center">
            <VerticalStackLayout Padding="28" Spacing="20">

                <!-- Logo / hero -->
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center" Margin="0,0,0,10">
                    <Border HeightRequest="80" WidthRequest="80" StrokeThickness="0" HorizontalOptions="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#7A59FF" Offset="0" />
                                <GradientStop Color="#40A7FF" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="28" />
                        </Border.StrokeShape>
                        <Label Text="💰" FontSize="40" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <Label Text="Smart Expense Tracker" FontSize="26" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#23264A, Dark=#F2F5FF}"
                           HorizontalOptions="Center" />
                    <Label Text="Sign in to continue" FontSize="14"
                           TextColor="{AppThemeBinding Light=#6B6E8E, Dark=#9BA0CC}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- Form card -->
                <Border Padding="22" StrokeThickness="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{AppThemeBinding Light=#FFFFFF, Dark=#20233E}" Offset="0" />
                            <GradientStop Color="{AppThemeBinding Light=#F8F6FF, Dark=#272A46}" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="18">

                        <!-- Username -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="USERNAME" FontSize="11" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#9B9FC0, Dark=#6B6E8E}" />
                            <Entry Placeholder="Enter username"
                                   Text="{Binding Username}"
                                   FontSize="16"
                                   BackgroundColor="Transparent"
                                   TextColor="{AppThemeBinding Light=#23264A, Dark=#F2F5FF}"
                                   PlaceholderColor="{AppThemeBinding Light=#CACAD8, Dark=#5A5D7E}" />
                            <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light=#E0E0F0, Dark=#3A3D5E}" />
                        </VerticalStackLayout>

                        <!-- Password -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="PASSWORD" FontSize="11" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#9B9FC0, Dark=#6B6E8E}" />
                            <Entry Placeholder="Enter password"
                                   Text="{Binding Password}"
                                   IsPassword="True"
                                   FontSize="16"
                                   BackgroundColor="Transparent"
                                   TextColor="{AppThemeBinding Light=#23264A, Dark=#F2F5FF}"
                                   PlaceholderColor="{AppThemeBinding Light=#CACAD8, Dark=#5A5D7E}" />
                            <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light=#E0E0F0, Dark=#3A3D5E}" />
                        </VerticalStackLayout>

                        <!-- Error message -->
                        <Label Text="{Binding ErrorMessage}"
                               TextColor="#FF5E6D"
                               FontSize="13"
                               IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"
                               HorizontalOptions="Center" />

                    </VerticalStackLayout>
                </Border>

                <!-- Login button -->
                <Border Padding="0" StrokeThickness="0" HeightRequest="54">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#7A59FF" Offset="0" />
                            <GradientStop Color="#40A7FF" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="27" />
                    </Border.StrokeShape>
                    <Button Text="Sign In"
                            Command="{Binding LoginCommand}"
                            BackgroundColor="Transparent"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="16" />
                </Border>

                <!-- Register link -->
                <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Spacing="4">
                    <Label Text="Don't have an account?"
                           FontSize="14"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=#6B6E8E, Dark=#9BA0CC}" />
                    <Label Text="Register"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#7A59FF"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToRegisterCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </StackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
